COMPOSE_PROJECT_NAME=omnicore-ai

POSTGRES_DB=omnicore
POSTGRES_USER=omnicore
POSTGRES_PASSWORD=omnicore
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=3000
CHROMA_PORT=8001

OMNICORE_ENV=development
OMNICORE_DEBUG=false
OMNICORE_DATABASE_URL=postgresql+asyncpg://omnicore:omnicore@postgres:5432/omnicore
OMNICORE_JWT_SECRET_KEY=change-this-before-sharing-or-deploying
OMNICORE_CORS_ORIGINS=["http://localhost:3000"]
OMNICORE_ENABLE_AI=true
OMNICORE_ENABLE_FORECASTING=true
OMNICORE_CHROMA_ENDPOINT_URL=http://chroma:8000
OMNICORE_CHROMA_COLLECTION_NAME=omnicore_knowledge
OMNICORE_PHI3_ENDPOINT_URL=

OMNICORE_API_BASE_URL=http://backend:8000/api/v1
