OMNICORE_ENV=local
OMNICORE_DEBUG=true
OMNICORE_APP_NAME=OmniCore AI API
OMNICORE_API_V1_PREFIX=/api/v1
OMNICORE_CORS_ORIGINS=["http://localhost:3000"]

OMNICORE_DATABASE_URL=postgresql+asyncpg://omnicore:omnicore@localhost:5432/omnicore
OMNICORE_DATABASE_ECHO=false

OMNICORE_JWT_SECRET_KEY=replace-with-a-long-random-secret
OMNICORE_JWT_ALGORITHM=HS256
OMNICORE_JWT_ISSUER=omnicore-ai
OMNICORE_JWT_AUDIENCE=omnicore-ai-api
OMNICORE_ACCESS_TOKEN_EXPIRE_MINUTES=15
OMNICORE_REFRESH_TOKEN_EXPIRE_DAYS=14

OMNICORE_LOG_LEVEL=INFO
OMNICORE_ENABLE_AI=false
OMNICORE_ENABLE_FORECASTING=false
OMNICORE_FORECASTING_MODEL_NAME=statistical-demand-forecaster
OMNICORE_FORECASTING_MODEL_VERSION=holt-linear-v1
OMNICORE_CHROMA_ENDPOINT_URL=http://localhost:8001
OMNICORE_CHROMA_COLLECTION_NAME=omnicore_knowledge
OMNICORE_PHI3_ENDPOINT_URL=
